generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            WorkspaceMember[]
  analyses           Analysis[]
  customRules        CustomRule[]
  auditLogs          AuditLog[]
  developerWebhooks  DeveloperWebhook[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  role        String    @default("member")
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Project {
  id        String     @id @default(cuid())
  repoUrl   String     @unique
  name      String
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}

/** Programmatic access: hashed keys, scoped to OAuth user id (GitHub `sub`). */
model ApiKey {
  id         String     @id @default(cuid())
  userId     String
  name       String
  /** SHA-256 hex of full secret (never store plaintext). */
  keyHash    String     @unique
  /** Short label e.g. act_abcd… for UI. */
  prefix     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  analyses Analysis[]

  @@index([userId])
}

model Analysis {
  id               String     @id @default(cuid())
  /** Set when the run was started by a signed-in user (browser or valid API key). */
  userId           String?
  apiKeyId         String?
  apiKey           ApiKey?    @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  workspaceId      String?
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /** Canonical repo URL (e.g. https://github.com/o/r). Null for paste-only runs. */
  repoUrl          String?
  /** Full PR URL when analysis was for a pull request. */
  prUrl            String?
  prNumber         Int?
  /** PR head SHA captured at analysis time. Enables stable GitHub
   *  permalinks from each finding on the result page — see
   *  `src/lib/github/evidenceLinks.ts`. Null for paste runs and for
   *  legacy analyses created before this column was added. */
  prHeadSha        String?
  score            Int
  decision         String
  previousScore    Int?
  previousDecision String?
  modelVersion     String   @default("deterministic-v1")
  summary          String
  prCommentUrl     String?
  prCommentId      String?
  /** Per-dimension scores 0–100 (security, logic, …). */
  dimensionScores  Json?
  inputJson        Json?
  outcome          String?
  createdAt        DateTime @default(now())
  issues           Issue[]
  sources          Source[]

  @@index([repoUrl])
  @@index([projectId])
  @@index([workspaceId])
  @@index([userId])
  @@index([apiKeyId])
}

model Issue {
  id          String   @id @default(cuid())
  analysisId  String
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  category    String
  severity    String
  description String
  filePath    String?
  lineNumber  Int?
}

model Source {
  id          String   @id @default(cuid())
  analysisId  String
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  url         String?
  title       String?
  excerpt     String?
  trustLevel  String?
}

/** User-defined pattern checks (simple substring or regex when pattern is /.../). */
model CustomRule {
  id          String     @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  pattern     String
  category    String
  severity    String
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId])
}

model AuditLog {
  id          String     @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actorUserId String?
  action      String
  meta        Json?
  createdAt   DateTime   @default(now())

  @@index([createdAt])
  @@index([workspaceId])
}

/**
 * Auto-analyze subscription for a single GitHub repository.
 *
 * Created when a signed-in user flips the "Auto-analyze" toggle on
 * `/connect`. The row stores the GitHub webhook id we installed on
 * their repo so we can remove it again on toggle-off. `fullName` is
 * the canonical `owner/repo` string and is unique per row — we never
 * stack more than one subscription on the same repo.
 */
model RepoSubscription {
  id        String   @id @default(cuid())
  /** OAuth `sub` of the user who enabled auto-analyze. */
  userId    String
  owner     String
  repo      String
  fullName  String   @unique
  /** GitHub webhook id returned by `POST /repos/{o}/{r}/hooks`. */
  hookId    Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/** Outbound HTTPS webhooks for analysis completion (user-defined URL). */
model DeveloperWebhook {
  id          String     @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  url         String
  secret      String?
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId])
}
